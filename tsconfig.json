{
  "include": ["src"],
  "compilerOptions": {
    "skipLibCheck": false,
    "outDir": "dist",
    "target": "es2018",
    "types": ["node"],
    "lib": ["dom", "esnext"],
    "declaration": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "esModuleInterop": true,
    "allowJs": true
  }
}
